{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Cor",
  "colors": {
    "primary": "#4F46E5",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/cor-logo-black.png",
    "dark": "/logo/cor-logo-white.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "concepts"
            ]
          },
          {
            "group": "SDK",
            "icon": "code",
            "pages": [
              "sdk/installation",
              "sdk/identifying-users",
              "sdk/widget-configuration",
              "sdk/sessions",
              "sdk/reference"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "icon": "book-open",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Session Reporting",
            "icon": "chart-line",
            "openapi": "/api-reference/openapi.json",
            "pages": [
              "GET /api/sessions/reporting",
              "GET /api/sessions/reporting/transcripts/{id}",
              "POST /api/sessions/reporting/transcripts"
            ]
          },
          {
            "group": "User Context",
            "icon": "user",
            "openapi": "/api-reference/openapi.json",
            "pages": [
              "POST /api/onboardee/context/"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.coragents.ai"
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://getcor.ai"
    }
  }
}
